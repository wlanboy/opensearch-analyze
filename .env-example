# Nach .env kopieren und Werte anpassen: cp .env-example .env
# docker-compose.yml und adduser.sh laden diese Datei automatisch,
# opensearch-analyze.py / opensearch-analyze-d.py ebenfalls.

# Bootstrap-Passwort für den OpenSearch-"admin"-User. Wird bei jedem
# Start der Container benötigt (nicht nur beim ersten Mal).
# Mindestens 8 Zeichen, je ein Groß-/Kleinbuchstabe, eine Ziffer und ein
# Sonderzeichen, sonst startet der Container nicht.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe123

# Ab hier: wird von adduser.sh automatisch angelegt/aktualisiert, sobald es
# gegen den laufenden Cluster ausgeführt wird (./adduser.sh). Manuelles
# Eintragen ist nur nötig, wenn der Analyzer gegen einen anderen, bereits
# gesicherten Cluster laufen soll.
OPENSEARCH_HOST=https://localhost:9200
OPENSEARCH_USER=opensearch-analyzer
OPENSEARCH_PASSWORD=
OPENSEARCH_INSECURE=true
